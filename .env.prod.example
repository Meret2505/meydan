# Copy to .env.prod on the VPS (DO NOT COMMIT). The compose file reads this.
# Generate strong values: openssl rand -base64 32

# --- Postgres ---
POSTGRES_USER=meydan
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
POSTGRES_DB=meydan

# --- App ---
# Must match the domain your DNS A record points at + the SSL cert.
NEXTAUTH_URL=https://example.com
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_base64_32

# Reuse the same Google OAuth client you used on Vercel; just add the new
# https://example.com/api/auth/callback/google to Authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- TLS bootstrap (used once by scripts/bootstrap-tls.sh) ---
DOMAIN=example.com
LETSENCRYPT_EMAIL=you@example.com
