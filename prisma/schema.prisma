generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Position {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum GameStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum GameType {
  OPEN
  TEAM_MATCH
}

enum NotificationType {
  GAME_INVITE
  SPOT_OPENED
  GAME_REMINDER
  RESULT_NEEDED
  PLAYER_JOINED
  GAME_CANCELLED
  TEAM_INVITE
}

model User {
  id             String     @id @default(cuid())
  email          String?    @unique
  name           String
  phone          String?
  password       String?
  avatar         String?
  position       Position?
  skillLevel     SkillLevel @default(BEGINNER)
  district       String?
  age            Int?
  isOpenToInvite Boolean    @default(true)
  fcmToken       String?
  locale         String     @default("ru")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  accounts         Account[]
  sessions         Session[]
  organizedGames   Game[]            @relation("Organizer")
  gameParticipants GameParticipant[]
  teamMemberships  TeamMember[]
  notifications    Notification[]
  sentInvites      GameInvite[]      @relation("InviteSender")
  receivedInvites  GameInvite[]      @relation("InviteReceiver")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Field {
  id        String   @id @default(cuid())
  name      String
  address   String
  district  String
  surface   String
  capacity  Int
  phone     String?
  photos    String[]
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  games Game[]

  @@map("fields")
}

model Game {
  id              String     @id @default(cuid())
  type            GameType   @default(OPEN)
  status          GameStatus @default(OPEN)
  scheduledAt     DateTime
  fieldId         String?
  fieldName       String?
  totalSpots      Int
  neededPositions Position[]
  notes           String?
  scoreHome       Int?
  scoreAway       Int?
  organizerId     String
  teamId          String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  field        Field?           @relation(fields: [fieldId], references: [id])
  organizer    User             @relation("Organizer", fields: [organizerId], references: [id])
  team         Team?            @relation(fields: [teamId], references: [id])
  participants GameParticipant[]
  invites      GameInvite[]

  @@index([scheduledAt])
  @@index([status])
  @@map("games")
}

model GameParticipant {
  id       String   @id @default(cuid())
  gameId   String
  userId   String
  attended Boolean?
  joinedAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@map("game_participants")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  district  String?
  createdAt DateTime @default(now())

  members     TeamMember[]
  games       Game[]
  homeMatches TournamentMatch[] @relation("HomeTeam")
  awayMatches TournamentMatch[] @relation("AwayTeam")

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  isCaptain Boolean  @default(false)
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Tournament {
  id          String    @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())

  matches TournamentMatch[]

  @@map("tournaments")
}

model TournamentMatch {
  id           String    @id @default(cuid())
  tournamentId String
  homeTeamId   String
  awayTeamId   String
  scheduledAt  DateTime?
  scoreHome    Int?
  scoreAway    Int?
  round        String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam   Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])

  @@map("tournament_matches")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model GameInvite {
  id         String   @id @default(cuid())
  gameId     String
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  game     Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sender   User @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([gameId, receiverId])
  @@map("game_invites")
}
